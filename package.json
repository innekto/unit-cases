{
  "name": "balancy-app-backend",
  "private": true,
  "version": "1.0.0",
  "description": "Nest TypeScript starter repository",
  "license": "MIT",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "postinstall": "npm run prepare",
    "build": "nest build",
    "lint:format": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "lint:fs": "ls-lint",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "lint:editor": "editorconfig-checker",
    "start:prod": "node dist/main",
    "lint:fast": "oxlint src test",
    "lint:js": "eslint --cache --cache-location .cache/eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "lint:type": "npx tsc --noEmit",
    "lint:js:fix": "eslint --cache --cache-location .cache/eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "lint": "npm run lint:format && npm run lint:fs && npm run lint:js && npm run lint:type",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "prepare": "husky install",
    "typeorm": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js -d src/database/data-source.ts",
    "migration:create": "npm run typeorm -- migration:create src/database/migrations/migration",
    "migration:generate": "npm run typeorm -- migration:generate src/database/migrations/migration --pretty",
    "migration:run": "npm run typeorm -- migration:run",
    "migration:revert": "npm run typeorm -- migration:revert",
    "migration:show": "npm run typeorm -- migration:show",
    "schema:drop": "npm run typeorm -- schema:drop",
    "seed:run": "ts-node -r tsconfig-paths/register ./src/database/seeds/run-seed.ts"
  },
  "dependencies": {
    "@nestjs/bullmq": "^1.0.0",
    "@nestjs/common": "^10.4.20",
    "@nestjs/config": "^3.0.0",
    "@nestjs/core": "^10.4.20",
    "@nestjs/jwt": "^10.1.0",
    "@nestjs/passport": "^10.0.0",
    "@nestjs/platform-express": "^10.4.20",
    "@nestjs/schedule": "^4.1.2",
    "@nestjs/swagger": "^7.1.11",
    "@nestjs/typeorm": "^10.0.0",
    "bcrypt": "^5.1.0",
    "bullmq": "^1.87.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "cloudinary": "^2.9.0",
    "cookie-parser": "^1.4.6",
    "date-fns": "^3.3.1",
    "ioredis": "^5.3.2",
    "joi": "^17.9.2",
    "nestjs-pino": "^4.6.1",
    "nodemailer": "^6.9.3",
    "passport": "^0.6.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pg": "^8.11.0",
    "pg-connection-string": "^2.9.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "streamifier": "^0.1.1",
    "swagger-ui-dist": "^5.29.1",
    "typeorm": "^0.3.16"
  },
  "devDependencies": {
    "@ls-lint/ls-lint": "^2.0.0",
    "@nestjs/cli": "^10.0.3",
    "@nestjs/schematics": "^10.0.1",
    "@nestjs/testing": "^10.4.20",
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "^4.17.17",
    "@types/jest": "^28.1.4",
    "@types/multer": "^1.4.7",
    "@types/node": "^20.3.1",
    "@types/nodemailer": "^6.4.15",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/streamifier": "^0.1.2",
    "@types/supertest": "^2.0.12",
    "@typescript-eslint/eslint-plugin": "^5.59.11",
    "@typescript-eslint/parser": "^5.59.11",
    "editorconfig-checker": "^5.1.0",
    "eslint": "^8.49.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-import": "^2.27.5",
    "eslint-plugin-prettier": "^4.2.1",
    "eslint-plugin-simple-import-sort": "^10.0.0",
    "husky": "^8.0.3",
    "jest": "^28.1.2",
    "oxlint": "^1.20.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^2.8.8",
    "source-map-support": "^0.5.21",
    "supertest": "^6.2.4",
    "ts-jest": "^28.0.5",
    "ts-loader": "^9.3.1",
    "ts-node": "^10.8.2",
    "tsconfig-paths": "^4.0.0",
    "typescript": "^5.5.3"
  }
}
